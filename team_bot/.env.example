# Teams bot configuration
BOT_APP_ID=
BOT_APP_PASSWORD=
BOT_BASE_URL=http://localhost:3978
BOT_MCP_SERVER_URL=http://localhost:8000
BOT_LOG_LEVEL=INFO

# Microsoft Graph — proactive meeting join via webhook
# Required Graph application permissions: OnlineMeetings.Read.All, Calendars.Read
BOT_GRAPH_TENANT_ID=
BOT_GRAPH_CLIENT_ID=
BOT_GRAPH_CLIENT_SECRET=
# Public HTTPS URL of this bot (used to register the Graph webhook subscription)
# Leave empty locally — bot will only join when manually added to a meeting
BOT_WEBHOOK_BASE_URL=
BOT_WEBHOOK_SECRET=change-me-in-production

# Orchestrator configuration prefix
ORCH_AZURE_AI_PROJECT_ENDPOINT=
ORCH_MCP_SERVER_URL=http://localhost:8000
