# Meeting Analyzer — environment variables template
# Copy to .env and fill in values for local development.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# MCP Server (prefix: MCP_)
# ---------------------------------------------------------------------------
MCP_BACKEND_MODE=mock           # mock | azure
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# Required when MCP_BACKEND_MODE=azure:
MCP_AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
MCP_COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443
MCP_GRAPH_TENANT_ID=<tenant-id>
MCP_GRAPH_CLIENT_ID=<client-id>
MCP_AZURE_REGION=eastus

# ---------------------------------------------------------------------------
# Orchestrator (prefix: ORCH_)
# ---------------------------------------------------------------------------
ORCH_FOUNDRY_MODE=mock          # mock | azure  (mock = no Azure AI Foundry needed)
ORCH_LOG_LEVEL=INFO
ORCH_MCP_SERVER_URL=http://localhost:8000
ORCH_TRANSCRIPT_CAPTURE_INTERVAL_SECONDS=60
ORCH_REALTIME_LOOP_INTERVAL_SECONDS=60
ORCH_REALTIME_LOOP_START_DELAY_SECONDS=120
ORCH_OFF_TRACK_CONSECUTIVE_WINDOWS=3
ORCH_OFF_TRACK_SIMILARITY_THRESHOLD=0.35
ORCH_AGENDA_UNCLEAR_THRESHOLD=0.4
ORCH_AGENDA_UNCLEAR_TRIGGER_MINUTES=5
ORCH_AGENDA_UNCLEAR_SECOND_ALERT_MINUTES=8
ORCH_PURPOSE_DETECTION_DELAY_SECONDS=120
ORCH_PURPOSE_DRIFT_CONSECUTIVE_MINUTES=5
ORCH_PURPOSE_RECHECK_INTERVAL_MINUTES=5
ORCH_TONE_ESCALATION_WINDOW_SECONDS=180
ORCH_PARTICIPATION_PULSE_INTERVAL_MINUTES=5
ORCH_SILENT_PARTICIPANT_THRESHOLD_MINUTES=10
ORCH_ALERT_THROTTLE_WINDOW_SECONDS=300
ORCH_SPECIALIST_AGENT_TIMEOUT_SECONDS=120
ORCH_MCP_RETRY_MAX_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Azure AI Foundry — shared across deploy scripts and orchestrator
# ---------------------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<ai-services-account>.services.ai.azure.com/api/projects/<project-name>
MCP_SERVER_URL=https://mcp.<env>.azurecontainerapps.io

# ---------------------------------------------------------------------------
# Azure identity — used by DefaultAzureCredential in all components
# Set these only if NOT using managed identity or az login locally.
# ---------------------------------------------------------------------------
# AZURE_CLIENT_ID=<service-principal-client-id>
# AZURE_CLIENT_SECRET=<service-principal-secret>
# AZURE_TENANT_ID=<tenant-id>
