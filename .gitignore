# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Environment — never commit real credentials
.env

# Dependency hash files (regenerated locally)
*.sha

# Agent IDs written by deploy scripts
deploy/agent_ids/
orchestrator/agent_ids.json

# Build artifacts
site/
dist/
build/

# Terraform — state and local config (never commit — contain plaintext secrets)
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
infra/terraform.tfvars

# Test cache
**/.pytest_cache/
